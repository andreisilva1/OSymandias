# ---------------------------------------------------------------------------
# Database
# Credentials must match docker-compose.yml service definitions.
# ---------------------------------------------------------------------------
POSTGRES_URL=postgresql+asyncpg://aios:aios@postgres:5432/aios

# ---------------------------------------------------------------------------
# Cache + Pub/Sub + Celery result backend
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Celery broker
# ---------------------------------------------------------------------------
RABBITMQ_URL=amqp://aios:aios@rabbitmq:5672/

# ---------------------------------------------------------------------------
# Vector store
# ---------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333

# ---------------------------------------------------------------------------
# Tracing (optional — remove if not using Jaeger)
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=osymandias

# ---------------------------------------------------------------------------
# CORS — comma-separated list of allowed frontend origins
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ---------------------------------------------------------------------------
# LLM — local (Ollama, free)
# Install: https://ollama.com  →  ollama pull llama3.2
# ---------------------------------------------------------------------------
LLM_DEFAULT_PROVIDER=ollama
LLM_DEFAULT_MODEL=llama3.2
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ---------------------------------------------------------------------------
# LLM — cloud providers (fill in at least one if not using Ollama)
# Add a key and restart Docker once. After that, switch agents between
# providers freely from the UI — no restart needed.
# WARNING: never commit this file with real keys filled in.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
AGENT_DEFAULT_MAX_ITERATIONS=20
AGENT_DEFAULT_TIMEOUT_SECONDS=120
HEARTBEAT_TIMEOUT_SECONDS=60
METRICS_CACHE_TTL_SECONDS=300

# ---------------------------------------------------------------------------
# Frontend (used by Next.js — must be set before `docker compose up`)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
