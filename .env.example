# ---------------------------------------------------------------------------
# LLM — fill in at least one provider
# ---------------------------------------------------------------------------
LLM_DEFAULT_PROVIDER=ollama
LLM_DEFAULT_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Cloud providers (uncomment and fill in the key you want to use)
# LLM_DEFAULT_PROVIDER=openai
# LLM_DEFAULT_MODEL=gpt-4o
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Infrastructure — managed by osy serve via OSY.compose.yml
# ---------------------------------------------------------------------------
POSTGRES_URL=postgresql+asyncpg://osy:osy@localhost:5432/osymandias
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
QDRANT_URL=http://localhost:6333

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
AGENT_DEFAULT_MAX_ITERATIONS=20
AGENT_DEFAULT_TIMEOUT_SECONDS=120
HEARTBEAT_TIMEOUT_SECONDS=60
METRICS_CACHE_TTL_SECONDS=300
